<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Экспорт для распространения вне App Store (Developer ID). -->
	<key>method</key>
	<string>developer-id</string>

	<!-- Автоматическая подпись через ваш аккаунт разработчика. -->
	<key>signingStyle</key>
	<string>automatic</string>

	<!-- ОБЯЗАТЕЛЬНО: подставьте ваш Team ID (Apple Developer → Membership). -->
	<key>teamID</key>
	<string>REPLACE_WITH_YOUR_TEAM_ID</string>

	<!-- Печатать manifest не нужно для Developer ID. -->
	<key>destination</key>
	<string>export</string>
</dict>
</plist>
